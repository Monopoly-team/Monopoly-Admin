<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:MonopolyAdminPanel.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
		xmlns:svg="using:Svg.Controls.Skia.Avalonia"
        mc:Ignorable="d"
        d:DesignWidth="1200"
        d:DesignHeight="700"
        x:Class="MonopolyAdminPanel.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="Admin panel"
        Width="1200"
        Height="700"
		WindowState="Maximized"
        MinWidth="900"
        MinHeight="600"
        Background="#151515">

	<Design.DataContext>
		<vm:MainWindowViewModel/>
	</Design.DataContext>

	<Grid Background="#151515">

		<Border Width="600"
                Padding="46"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="#2A2729"
                CornerRadius="18">

			<StackPanel Spacing="26">

				<StackPanel HorizontalAlignment="Center" Spacing="8">
					<Svg Path="/Assets/logo3.svg"
						 Width="300"
						 Height="300"
						 HorizontalAlignment="Center"/>

					<TextBlock Text="Админ-панель"
							   FontSize="28"
							   FontWeight="SemiBold"
							   Foreground="White"
							   HorizontalAlignment="Center"/>

					<TextBlock Text="TCP Monopoly"
							   FontSize="15"
							   Foreground="#A8A8A8"
							   HorizontalAlignment="Center"/>
				</StackPanel>

				<Border Height="1"
                        Background="#555"
                        Margin="30,6"/>

				<StackPanel Spacing="18">

					<TextBox PlaceholderText="IP сервера"
                                Height="52"
                                FontSize="18"
                                Padding="16,0"
                                Background="#1E1E1E"
                                Foreground="White"
                                BorderBrush="#3A3A3A"
                                BorderThickness="2"
                                CornerRadius="6"
								VerticalContentAlignment="Center">

						<TextBox.Styles>
							<Style Selector="TextBox:focus">
								<Setter Property="Background" Value="#D8D8D8"/>
								<Setter Property="Foreground" Value="#111111"/>
								<Setter Property="BorderBrush" Value="#FFFFFF"/>
							</Style>
						</TextBox.Styles>

					</TextBox>

					<TextBox PlaceholderText="Пароль администратора"
                                Height="52"
                                FontSize="18"
                                Padding="16,0"
                                Background="#1E1E1E"
                                Foreground="White"
                                BorderBrush="#3A3A3A"
                                BorderThickness="2"
                                CornerRadius="6"
                                PasswordChar="●"
								VerticalContentAlignment="Center">

						<TextBox.Styles>
							<Style Selector="TextBox:focus">
								<Setter Property="Background" Value="#D8D8D8"/>
								<Setter Property="Foreground" Value="#111111"/>
								<Setter Property="BorderBrush" Value="#FFFFFF"/>
							</Style>
						</TextBox.Styles>

					</TextBox>

					<Button Content="Войти"
                            Width="220"
                            Height="50"
                            HorizontalAlignment="Center"
							HorizontalContentAlignment="Center"
							VerticalContentAlignment="Center"
                            FontSize="18"
                            Background="#3A3A3A"
                            Foreground="White"
                            BorderThickness="0"
                            CornerRadius="4"
							Click="LoginButton_Click"/>

				</StackPanel>

			</StackPanel>

		</Border>

	</Grid>
</Window>