<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:MonopolyAdminPanel.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:svg="using:Svg.Controls.Skia.Avalonia"
        mc:Ignorable="d"
        d:DesignWidth="1200"
        d:DesignHeight="700"
        x:Class="MonopolyAdminPanel.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="Admin panel"
        Width="1200"
        Height="700"
        WindowState="Maximized"
        MinWidth="900"
        MinHeight="600"
        Background="#151515">

	<Design.DataContext>
		<vm:MainWindowViewModel/>
	</Design.DataContext>

	<Window.Styles>
		<Style Selector="TextBox.loginTextBox">
			<Setter Property="Height" Value="52"/>
			<Setter Property="FontSize" Value="18"/>
			<Setter Property="Padding" Value="16,0"/>
			<Setter Property="Background" Value="#1E1E1E"/>
			<Setter Property="Foreground" Value="White"/>
			<Setter Property="WatermarkForeground" Value="#8A8A8A"/>
			<Setter Property="BorderBrush" Value="#3A3A3A"/>
			<Setter Property="BorderThickness" Value="2"/>
			<Setter Property="CornerRadius" Value="6"/>
			<Setter Property="VerticalContentAlignment" Value="Center"/>
		</Style>

		<Style Selector="TextBox.loginTextBox:focus">
			<Setter Property="Background" Value="#24242A"/>
			<Setter Property="Foreground" Value="White"/>
			<Setter Property="BorderBrush" Value="#6B6B78"/>
		</Style>
	</Window.Styles>

	<Grid Background="#151515">
		<Border Width="600"
                Padding="46"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="#2A2729"
                CornerRadius="18">

			<StackPanel Spacing="26">
				<StackPanel HorizontalAlignment="Center" Spacing="8">
					<Svg Path="/Assets/logo3.svg"
                         Width="300"
                         Height="300"
                         HorizontalAlignment="Center"/>

					<TextBlock Text="Админ-панель"
                               FontSize="28"
                               FontWeight="SemiBold"
                               Foreground="White"
                               HorizontalAlignment="Center"/>

					<TextBlock Text="TCP Monopoly"
                               FontSize="15"
                               Foreground="#A8A8A8"
                               HorizontalAlignment="Center"/>
				</StackPanel>

				<Border Height="1"
                        Background="#555"
                        Margin="30,6"/>

				<StackPanel Spacing="18">
					<TextBox x:Name="IpTextBox"
                             Classes="loginTextBox"
                             PlaceholderText="IP сервера"/>

					<TextBox Classes="loginTextBox"
                             PlaceholderText="Пароль администратора"
                             PasswordChar="●"/>

					<Button Content="Войти"
                            Width="220"
                            Height="50"
                            HorizontalAlignment="Center"
                            HorizontalContentAlignment="Center"
                            VerticalContentAlignment="Center"
                            FontSize="18"
                            Background="#3A3A3A"
                            Foreground="White"
                            BorderThickness="0"
                            CornerRadius="4"
                            Click="LoginButton_Click"/>
				</StackPanel>
			</StackPanel>
		</Border>
	</Grid>
</Window>