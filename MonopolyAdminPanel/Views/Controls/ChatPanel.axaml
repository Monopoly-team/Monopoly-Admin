<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="MonopolyAdminPanel.Views.Controls.ChatPanel">

	<Border Background="#1F1F24"
			CornerRadius="10"
			Padding="16">

		<Grid RowDefinitions="Auto,*,Auto">

			<TextBlock Grid.Row="0"
					   Text="ЧАТ"
					   Foreground="White"
					   FontSize="17"
					   FontWeight="SemiBold"/>

			<ScrollViewer x:Name="ChatScrollViewer"
						  Grid.Row="1"
						  Margin="0,10,0,10">

				<StackPanel x:Name="MessagesPanel"
							Spacing="8"/>

			</ScrollViewer>

			<TextBox x:Name="ChatMessageTextBox"
					 Grid.Row="2"
					 Height="38"
					 Watermark="Сообщение в общий чат..."
					 FontSize="14"
					 KeyDown="ChatMessageTextBox_KeyDown"/>

		</Grid>

	</Border>

</UserControl>