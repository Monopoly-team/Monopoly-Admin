<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="MonopolyAdminPanel.Views.Controls.OnlinePlayersPanel">

	<Border Background="#1F1F24"
			CornerRadius="10"
			Padding="16">

		<Grid RowDefinitions="Auto,*">

			<TextBlock Grid.Row="0"
					   Text="ИГРОКИ ОНЛАЙН"
					   FontSize="18"
					   Foreground="White"
					   FontWeight="SemiBold"
					   Margin="0,0,0,12"/>

			<ScrollViewer Grid.Row="1">
				<StackPanel x:Name="OnlinePlayersStackPanel"
							Spacing="12"/>
			</ScrollViewer>

		</Grid>

	</Border>

</UserControl>