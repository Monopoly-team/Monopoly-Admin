						<Border Grid.Row="0" Background="#2F3136"/>
						<Grid Grid.Row="1">
							<Svg Path="/Assets/alfa.svg"
								 Width="70"
								 Height="70"
								 HorizontalAlignment="Center"
								 VerticalAlignment="Center">
								<Svg.RenderTransform>
									<RotateTransform Angle="-90"/>
								</Svg.RenderTransform>
							</Svg>
						</Grid>
						<Border Grid.Row="2" Background="#6EE7A8"/>
