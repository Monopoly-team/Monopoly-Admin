								</Svg.RenderTransform>
							</Svg>
						</Grid>
						<Border Grid.Row="2" Background="#4DDBFF"/>
					</Grid>
				</Border>

				<Border Grid.Row="0" Grid.Column="4" Background="#F4F4F4" BorderBrush="#111" BorderThickness="1">
