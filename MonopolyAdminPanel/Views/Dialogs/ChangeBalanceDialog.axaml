<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="MonopolyAdminPanel.Views.Dialogs.ChangeBalanceDialog"
        Width="520"
        Height="380"
        CanResize="False"
        SystemDecorations="None"
        Background="Transparent">

    <Border Background="#25252B"
            BorderBrush="#3A3A45"
            BorderThickness="1"
            CornerRadius="12"
            Padding="24">

        <StackPanel Spacing="16">

            <Border Background="Transparent"
                    PointerPressed="TitleBar_PointerPressed">

                <TextBlock Text="Изменить баланс"
                           FontSize="22"
                           FontWeight="SemiBold"
                           Foreground="White"/>
            </Border>

            <TextBlock Text="Игрок"
                       Foreground="#B8B8B8"/>

            <ComboBox x:Name="PlayersComboBox"
                      Height="38"/>

            <TextBlock Text="Новый баланс"
                       Foreground="#B8B8B8"/>

            <TextBox x:Name="BalanceTextBox"
                     Height="38"
                     Watermark="Например: 10000"/>

            <TextBlock Text="Причина (необязательно)"
                       Foreground="#B8B8B8"/>

            <TextBox x:Name="ReasonTextBox"
                     Height="38"/>

            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Spacing="20"
                        Margin="0,10,0,0">

                <Button Content="Отмена"
                        Width="120"
                        HorizontalContentAlignment="Center"
                        VerticalContentAlignment="Center"
                        Click="CancelButton_Click"/>

                <Button Content="Продолжить"
                        Width="120"
                        HorizontalContentAlignment="Center"
                        VerticalContentAlignment="Center"
                        Click="ConfirmButton_Click"/>

            </StackPanel>

        </StackPanel>

    </Border>

</Window>